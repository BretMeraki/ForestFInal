# Local Development Environment Configuration

# Database Configuration
# Local PostgreSQL (default)
DATABASE_URL=postgresql+psycopg2://postgres:woozyBoi0!@127.0.0.1:5432/postgres
SQLALCHEMY_DATABASE_URL=postgresql+psycopg2://postgres:woozyBoi0!@127.0.0.1:5432/postgres
DB_CONNECTION_STRING=postgresql+psycopg2://postgres:woozyBoi0!@127.0.0.1:5432/postgres

# Google Cloud SQL Connection String (for cloud deployment)
GOOGLE_CLOUD_SQL_CONNECTION_STRING=postgresql+psycopg2://postgres:woozyBoi0!@/postgres?host=/cloudsql/winged-verbena-457705-p3:us-central1:forestapp

# Google Cloud SQL instance configuration
# Only needed when DEPLOYMENT_MODE=cloud
INSTANCE_CONNECTION_NAME=winged-verbena-457705-p3:us-central1:forestapp
GOOGLE_CLOUD_PROJECT=winged-verbena-457705-p3

# Deployment Mode
# Options: 'local' or 'cloud'
DEPLOYMENT_MODE=local

# Debug settings for Streamlit
STREAMLIT_DEBUG_MODE=true

# Google Cloud Platform Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# GCP Service Account Credentials
GCP_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT_KEY_PATH=/path/to/your/service-account-key.json

# Cloud SQL Proxy Configuration
CLOUD_SQL_INSTANCE_CONNECTION_NAME=your-project:your-region:your-instance-name
CLOUD_SQL_PROXY_PORT=5432

# Security Configuration
SECRET_KEY=forest_local_dev_secret_key_very_secure_2025

ACCESS_TOKEN_EXPIRE_MINUTES=60

# Backend Configuration
BACKEND_URL=http://localhost:8000
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging Configuration
LOG_LEVEL=DEBUG

# Feature Flags
FEATURE_ENABLE_CORE_ONBOARDING=True
FEATURE_ENABLE_CORE_HTA=True
FEATURE_ENABLE_CORE_TASK_ENGINE=True

# External API Keys (using mock values for local development)
GOOGLE_API_KEY=mock_api_key_for_local_dev
GEMINI_MODEL_NAME=gemini-1.5-flash-latest
GEMINI_ADVANCED_MODEL_NAME=gemini-1.5-pro-latest

# Disable any cloud-specific features
USE_CLOUD_SQL_PROXY=False
ENABLE_CLOUD_SERVICES=False
LOCAL_DEVELOPMENT=True

# Explicitly unset these cloud variables
GCP_SA_KEY=
INSTANCE_CONNECTION_NAME=
GOOGLE_APPLICATION_CREDENTIALS=
